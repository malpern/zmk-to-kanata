                # Input is a Path - read the file
                content = file_path_or_content.read_text()
                logger.debug("Parsing ZMK file: %s", file_path_or_content)
            else:
                # Input is a string - use directly
                content = file_path_or_content
                logger.debug("Parsing ZMK content from string")
    
            # Process file line by line
            lines = content.split('\n')
            idx = 0
            while idx < len(lines):
                self.logger.debug(f"[DEBUG] Main loop before line {idx+1}: state={self.state}")
                line = lines[idx].strip()
    
                if not line or line.startswith('//'):
                    self.current_line += 1
                    idx += 1
                    continue
    
                reparsed = False
                while True:
