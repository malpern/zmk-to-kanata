    def _parse_line_with_reparse(self, line: str):
        """
        Like _parse_line, but returns 'REPARSE' if the state changed and the line should be reparsed.
        """
        try:
            self.logger.debug(f"[DEBUG] Before parsing line {self.current_line}: state={self.state}, line='{line}'")
            if self.state == ParserState.INITIAL:
                if 'keymap {' in line:
                    self._transition_to(ParserState.IN_KEYMAP)
                    return 'REPARSE'
            elif self.state == ParserState.IN_KEYMAP:
                if '_layer {' in line:
                    name = self._extract_layer_name(line)
                    self._start_new_layer(name)
                    return None
            elif self.state in (
                ParserState.IN_LAYER,
                ParserState.IN_BEHAVIORS,
                ParserState.IN_CONDITIONAL_LAYER
            ):
                if '_layer {' in line:
                    if self.state == ParserState.IN_LAYER:
                        # Instead of error, finish current layer and start new sibling layer
                        self.logger.debug(f"[DEBUG] Finishing current layer to allow sibling layer at line {self.current_line}, state={self.state}, line='{line}'")
                        self._finish_current_layer()
                        # After finishing, state is now IN_KEYMAP, so reparse this line
                        return 'REPARSE'
                    else:
                        name = self._extract_layer_name(line)
                        self._start_new_layer(name)
                        return 'REPARSE'
                elif 'bindings = <' in line:
                    self._parse_bindings_start(line)
                elif '>;' in line:
                    if self.state == ParserState.IN_LAYER:
                        if line.strip() == '};':
                            self._finish_current_layer()
                            return 'REPARSE'
                    else:
                        self._transition_to(ParserState.IN_KEYMAP)
                        return 'REPARSE'
                elif self.state == ParserState.IN_BEHAVIORS:
                    if '>' in line:
                        self._transition_to(ParserState.IN_LAYER)
                        return 'REPARSE'
                    else:
                        self._parse_binding_line(line)
                elif self.state == ParserState.IN_LAYER:
                    self._parse_binding_line(line)
            else:
                # Default fallback for unknown state
                pass
        except Exception as e:
            self.logger.error(
                f"Error parsing line {self.current_line}: {line}"
            )
